TITLE=Photo Stream
EMAIL=
AUTHOR_NAME=
AUTHOR_EMAIL=
AUTHOR_WEBSITE=
DESCRIPTION=A simple self-hosted photo stream.
BASEURL=
# URL must NOT end with / or links will be messed up.
URL=http://localhost:4000

SHOW_RSS_FEED=1
SHOW_OFFICIAL_GITHUB=0
HEADER_ENABLED=0
HEADER_BACKGROUND_COLOR=#ffffff
ALLOW_ORDER_SORT_CHANGE=1
ALLOW_ORIGINAL_DOWNLOAD=0
ALLOW_INDEXING=1
ALLOW_IMAGE_SHARING=1

# Default behavior serves _site immediately and rebuilds in the background.
# If _site is empty, a temporary page is served while the first build runs.
# Set PHOTO_STREAM_SERVE_MODE=jekyll to block startup until generation finishes.
# Set PHOTO_STREAM_SERVE_MODE=static or PHOTO_STREAM_BUILD_ON_START=0 to skip
# generation on container restart when _site already exists.
# Set PHOTO_STREAM_INCREMENTAL=1 to pass --incremental to Jekyll.
PHOTO_STREAM_BUILD_ON_START=1
PHOTO_STREAM_SERVE_MODE=background
PHOTO_STREAM_INCREMENTAL=0

# Optional internal admin dashboard. The admin starts automatically when a
# password is configured, or when PHOTO_STREAM_ADMIN_ENABLED=1 is set.
PHOTO_STREAM_ADMIN_ENABLED=1
PHOTO_STREAM_ADMIN_USERNAME=admin
PHOTO_STREAM_ADMIN_PASSWORD=
PHOTO_STREAM_ADMIN_PORT=4001
PHOTO_STREAM_ADMIN_HOST=0.0.0.0
PHOTO_DATA_PATH=./_data

# The host path mounted to /photo-stream/photos when using Docker Compose.
PHOTO_PATH=./photos

# Default sort order is newest to oldest images. Set to 1 to show oldest first.
DEFAULT_REVERSE_SORT=0

# Leave blank to disable.
TWITTER_USERNAME=
GITHUB_USERNAME=
INSTAGRAM_USERNAME=
CUSTOM_LINK_NAME=
CUSTOM_LINK_URL=

# Optional deployment script settings.
SYNCUSER=
SYNCPASS=
SYNCSERVER=
SYNCFOLDER=

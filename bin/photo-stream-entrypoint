#!/bin/sh
set -eu

HOST="${HOST:-0.0.0.0}"
PORT="${PORT:-4000}"
BUILD_ON_START="${PHOTO_STREAM_BUILD_ON_START:-1}"
SERVE_MODE="${PHOTO_STREAM_SERVE_MODE:-background}"
INCREMENTAL="${PHOTO_STREAM_INCREMENTAL:-0}"
SITE_DIR="/photo-stream/_site"

build_args() {
  if [ "$INCREMENTAL" = "1" ]; then
    printf '%s\n' "--trace --incremental"
  else
    printf '%s\n' "--trace"
  fi
}

run_build() {
  # shellcheck disable=SC2046
  bundle exec jekyll build $(build_args)
}

run_jekyll_serve() {
  # shellcheck disable=SC2046
  exec bundle exec jekyll serve --host "$HOST" --port "$PORT" $(build_args)
}

create_placeholder_site() {
  mkdir -p "$SITE_DIR"
  cat > "$SITE_DIR/index.html" <<'HTML'
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="30">
  <title>Photo Stream is generating</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      align-items: center;
      display: flex;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      justify-content: center;
      margin: 0;
      min-height: 100vh;
      padding: 2rem;
    }
    main { max-width: 34rem; }
    h1 { font-size: 1.75rem; margin: 0 0 0.75rem; }
    p { line-height: 1.5; margin: 0; }
  </style>
</head>
<body>
  <main>
    <h1>Photo Stream is generating</h1>
    <p>The site is being built in the background. This page will refresh automatically.</p>
  </main>
</body>
</html>
HTML
}

start_background_build() {
  (
    run_build &&
      echo "Background Jekyll build completed." ||
      echo "Background Jekyll build failed; continuing to serve existing _site."
  ) &
}

serve_static() {
  echo "Serving existing static site from $SITE_DIR on $HOST:$PORT"
  exec ruby -run -e httpd "$SITE_DIR" -b "$HOST" -p "$PORT"
}

if [ "$SERVE_MODE" = "background" ]; then
  if [ ! -f "$SITE_DIR/index.html" ]; then
    echo "No existing _site/index.html found; serving a temporary page while Jekyll builds in the background."
    create_placeholder_site
  else
    echo "Starting background Jekyll build while serving existing _site."
  fi

  start_background_build
  serve_static
fi

if [ "$SERVE_MODE" = "static" ] || [ "$BUILD_ON_START" = "0" ]; then
  if [ ! -f "$SITE_DIR/index.html" ]; then
    echo "No existing _site/index.html found; running one build before static serve."
    run_build
  fi

  serve_static
fi

run_jekyll_serve
